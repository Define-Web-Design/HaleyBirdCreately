{
  "run": {
    "commands": {
      "start-server": "/home/runner/workspace/node_bin/node simple-server.js"
    },
    "name": "start-server",
    "title": "Start Server",
    "description": "Starts the Creately code snippet server",
    "persistent": true
  },
  "lsp": {
    "display": {
      "node": "nodejs-20",
      "js": "nodejs-20",
      "ts": "nodejs-20",
      "jsx": "nodejs-20",
      "tsx": "nodejs-20"
    }
  },
  "language": "nodejs-20",
  "entrypoint": "simple-server.js",
  "hosting": {
    "route": "/",
    "directory": "public"
  },
  "deployment": {
    "run": ["/home/runner/workspace/node_bin/node", "simple-server.js"],
    "deploymentTarget": "cloudrun"
  },
  "ports": [
    {
      "localPort": 3000,
      "externalPort": 80
    }
  ]
}