# Environment Variables

# Database
DATABASE_URL=postgresql://username:password@hostname:port/database

# PageSpeed Insights API Key
PAGESPEED_INSIGHTS_API_KEY=your_api_key_here

# App Configuration
NODE_ENV=development
PORT=3000
# Application Settings
APP_NAME=Creately
APP_VERSION=1.0.0
NODE_ENV=development
DEBUG=true

# Feature Flags
FEATURE_AI_CHAT=true
FEATURE_CODE_ASSISTANCE=true
FEATURE_ANALYTICS=true
FEATURE_COLOR_PALETTES=true
FEATURE_MOOD_CAPSULES=true

# Server Settings
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Session Settings
SESSION_SECRET=change-this-to-a-random-string
SESSION_MAX_AGE=86400000

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=creately
DB_SSL=false
DB_POOL_SIZE=10

# AI Service API Keys
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_ORGANIZATION=

MISTRAL_API_KEY=
MISTRAL_DEFAULT_MODEL=mistral-large-latest

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-opus-20240229

PERPLEXITY_API_KEY=
PERPLEXITY_DEFAULT_MODEL=llama-3-sonar-large-32k-online

GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-pro

# Authentication
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRES_IN=24h

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Logging
LOG_LEVEL=info
LOG_OUTPUTS=console,file
LOG_FILE_PATH=logs/app.log
