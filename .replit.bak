run = ["sh", "-c", "./run-server.sh"]

[nix]
channel = "stable-22_11"

[env]
PORT = "8080"

[[ports]]
localPort = 8080
externalPort = 80

[packager]
language = "nodejs"

[packager.features]
packageSearch = true
guessImports = true

[languages.javascript]
pattern = "**/*.{js,jsx,ts,tsx}"
syntax = "javascript"

[languages.javascript.languageServer]
start = ["typescript-language-server", "--stdio"]

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]