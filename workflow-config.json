{
  "version": "1.0.0",
  "defaultWorkflow": "development",
  "defaultNodeEnv": "development",
  "fallbackEnabled": true,
  "fallbackPort": 3000,
  "workflows": [
    {
      "name": "development",
      "description": "Run the application in development mode with live reloading",
      "command": "NODE_ENV=development npm run dev",
      "dependencies": ["typescript", "tsx", "express"],
      "requiredFiles": ["server/index.ts", "package.json"]
    },
    {
      "name": "production",
      "description": "Build and run the application in production mode",
      "command": "NODE_ENV=production npm run build && NODE_ENV=production node dist/server/index.js",
      "dependencies": ["typescript", "express"],
      "requiredFiles": ["server/index.ts", "package.json"]
    },
    {
      "name": "deploy",
      "description": "Build and deploy the application",
      "command": "npm install --include=dev && NODE_ENV=production npm run build && NODE_ENV=production node dist/server/index.js",
      "dependencies": ["typescript", "express", "tailwindcss", "postcss", "autoprefixer"],
      "requiredFiles": ["server/index.ts", "package.json"]
    },
    {
      "name": "database",
      "description": "Update database schema",
      "command": "npm run db:push",
      "dependencies": ["drizzle-kit"],
      "requiredFiles": ["drizzle.config.ts", "shared/schema.ts"]
    },
    {
      "name": "test",
      "description": "Run tests",
      "command": "npm test",
      "dependencies": ["typescript", "vitest"],
      "requiredFiles": ["package.json"]
    },
    {
      "name": "lint",
      "description": "Lint and format code",
      "command": "npm run lint",
      "dependencies": ["eslint"],
      "requiredFiles": ["package.json"]
    }
  ],
  "environments": {
    "development": {
      "port": 3000,
      "host": "0.0.0.0",
      "logging": "verbose",
      "fallbackEnabled": true
    },
    "production": {
      "port": 3000,
      "host": "0.0.0.0",
      "logging": "error",
      "fallbackEnabled": true
    },
    "test": {
      "port": 3001,
      "host": "localhost",
      "logging": "silent",
      "fallbackEnabled": false
    }
  },
  "dependencies": {
    "required": ["node", "npm"],
    "optional": ["jq"]
  },
  "fallbacks": {
    "dependencyInstallCommands": [
      "npm install",
      "npm install --legacy-peer-deps",
      "npm install --no-optional"
    ],
    "buildCommands": [
      "npm run build",
      "npx tsc",
      "npx esbuild server/index.ts --bundle --platform=node --outfile=dist/server/index.js"
    ]
  }
}