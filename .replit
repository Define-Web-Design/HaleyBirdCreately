args = "# Run the comprehensive validation"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"require('./client/src/utils/validate-implementation.js').validateImplementation().then(require('./client/src/utils/validate-implementation.js').displayValidationResults)\""

