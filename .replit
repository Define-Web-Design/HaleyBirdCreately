args = "node -e \"require('./client/src/utils/consolidated-validation.js').runCompleteWorkflowValidation('Ensure all links work, validate form submissions, and check accessibility of all pages').then(success => { console.log(success ? 'All tasks validated successfully!' : 'Task validation failed'); process.exit(success ? 0 : 1); })\""

