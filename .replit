args = "npm run lint"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsc --noEmit"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
