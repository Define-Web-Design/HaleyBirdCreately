
run = "bash start-server.sh"
entrypoint = "simple-server.js"

[languages]
nodejs = "nodejs-20"

[nix]
channel = "stable-23_11"

[hosting]
route = "/"
directory = "public"

[deployment]
run = ["sh", "-c", "bash start-server.sh"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80
