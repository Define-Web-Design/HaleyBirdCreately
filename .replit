task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run the complete validation suite with checkpointing controls"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  const { taskOrchestrator } = require('./client/src/utils/task-validation-orchestrator');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  const { runFullSystemValidation, displayFullValidationResults } = require('./client/src/utils/consolidated-validation');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  // First run the full system validation"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  runFullSystemValidation().then(report => {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    displayFullValidationResults(report);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    // Only create a checkpoint if everything passes"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    if (report.overallSuccess) {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      const checkpointResult = taskOrchestrator.createCheckpoint();"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      console.log('CHECKPOINT STATUS:', checkpointResult.message);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      process.exit(0);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    } else {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      console.error('VALIDATION FAILED: No checkpoint created - tasks incomplete or errors detected');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      console.log('Fix the issues reported above before attempting to create a checkpoint');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      process.exit(1);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    }"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  }).catch(error => {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.error('FATAL ERROR:', error);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    process.exit(1);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  });"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "\""

