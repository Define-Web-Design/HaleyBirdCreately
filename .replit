args = "NODE_ENV=development MOBILE_OPTIMIZED=true npm run dev &"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 5"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run comprehensive mobile tests"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"Running comprehensive mobile testing suite...\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  const { testAppResponsiveness } = require('./client/src/utils/responsive-tester.js');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  const { runAccessibilityAudit } = require('./client/src/utils/navigation-tester.js');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  // Run both tests in parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  Promise.all(["

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    testAppResponsiveness(),"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    runAccessibilityAudit()"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  ]).then(([responsiveResults, a11yResults]) => {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.log('=== MOBILE RESPONSIVENESS RESULTS ===');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.log(JSON.stringify(responsiveResults.summary, null, 2));"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = '''    console.log('\\n=== ACCESSIBILITY RESULTS ===');'''

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.log('Score:', a11yResults.score, '/ 100');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = '''    console.log('\\n=== OVERALL VALIDATION ===');'''

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    const passed = responsiveResults.success && a11yResults.score >= 80;"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.log(passed ? '✅ ALL TESTS PASSED' : '❌ SOME TESTS FAILED');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = '''    console.log('\\n=== RECOMMENDATIONS ===');'''

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    [...(responsiveResults.recommendations || []), ...(a11yResults.recommendations || [])].forEach(rec => {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      console.log('- ' + rec);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    });"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  });"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "\""

