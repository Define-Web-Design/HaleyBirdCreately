args = "echo \"Running code cleanup and formatting...\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx prettier --write \"client/src/**/*.{ts,tsx}\" \"server/**/*.ts\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run the comprehensive validation with debug logs"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo \"Starting comprehensive validation and debugging...\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  const { taskOrchestrator } = require('./client/src/utils/task-validation-orchestrator');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  const { runFullSystemValidation, displayFullValidationResults } = require('./client/src/utils/consolidated-validation');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  console.log('Running comprehensive validation with debugging...');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  runFullSystemValidation().then(report => {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    displayFullValidationResults(report);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.log('Validation complete - check results above');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    // Log performance metrics"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.log('Performance metrics:');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.log('====================');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    const sections = report.sections.filter(s => s.name.includes('API') || s.name.includes('Performance'));"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    sections.forEach(section => {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      console.log(`${section.name}: ${section.success ? 'PASSED' : 'FAILED'}`);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      console.log(JSON.stringify(section.details, null, 2));"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    });"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  }).catch(err => {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    console.error('Validation error:', err);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "  });"

