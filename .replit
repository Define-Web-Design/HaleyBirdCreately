[[workflows.workflow]]
name = "Comprehensive Debug and Validation"
author = 40896524
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Kill any running processes first"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f node || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run code quality checks - lint and type check in parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run lint & npx tsc --noEmit & wait"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Start with basic code cleanup"

