args = "    console.log(result.validationReport);"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    "

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    // Create batch verification for pending tasks"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "    if (!result.canProceedToCheckpoint) {"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      console.log('Running batch verification for remaining tasks...');"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "      taskOrchestrator.batchVerifyAllTasks("

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "        Object.entries(result.tasksStatus)"

[[workflows.workflow.tasks]]
