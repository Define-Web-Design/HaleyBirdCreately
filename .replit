args = "# Run API endpoint validation"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const { validateApiEndpoints, generateApiValidationReport } = require('./client/src/utils/api-validator.js'); validateApiEndpoints().then(results => { console.log(generateApiValidationReport(results.results)); })\""

[[workflows.workflow.tasks]]
