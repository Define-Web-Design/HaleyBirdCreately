[[workflows.workflow]]
name = "Task-Specific Validation"
author = 40896524
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Kill any running processes"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f node || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run validation for specific tasks (customize this with your instruction)"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"require('./client/src/utils/consolidated-validation.js').runCompleteWorkflowValidation('Ensure all links work, validate form submissions, and check accessibility of all pages').then(success => { console.log(success ? 'All tasks validated successfully!' : 'Task validation failed'); process.exit(success ? 0 : 1); })\""

[[workflows.workflow]]
name = "Comprehensive Task Verification"
author = 40896524
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Kill any running processes first"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f node || true"

