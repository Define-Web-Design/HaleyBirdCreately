[[workflows.workflow]]
name = "Comprehensive Verification"
author = 40896524
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Kill any running processes first"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f node || true"

