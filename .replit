task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run the comprehensive app status check"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"require('./client/src/utils/app-status-cli.ts').runAppStatusCheck()\""

