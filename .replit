[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const { securityMonitor } = require('./server/services/securityMonitor.js'); securityMonitor.validateAssetIntegrity().then(results => console.log(JSON.stringify(results, null, 2)))\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run the accessibility audit"

[[workflows.workflow.tasks]]
task = "shell.exec"
