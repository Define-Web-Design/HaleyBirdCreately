[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"require('./client/src/utils/comprehensive-validation.js').verifyBeforeCheckpoint().then(canProceed => { process.exit(canProceed ? 0 : 1); })\""

[[workflows.workflow]]
name = "Simultaneous Task Validator"
author = 40896524
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Kill any running processes first"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f node || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run the comprehensive validation utility"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const { createStandardWorkflow, addWorkflowTask, completeWorkflowTask, validateWorkflowForCheckpoint, createWorkflowCheckpoint } = require('./client/src/utils/workflow-validator.js'); const { createVerifiedCheckpoint } = require('./client/src/utils/checkpoint-manager.js'); async function run() { const workflow = createStandardWorkflow('Full System Validation'); const taskId = addWorkflowTask({ description: 'Validate all implemented tasks', category: 'testing' }); await completeWorkflowTask(taskId); const result = await validateWorkflowForCheckpoint(); console.log(JSON.stringify(result, null, 2)); if (result.canCheckpoint) { await createWorkflowCheckpoint('All tasks validated successfully'); } } run();\""
