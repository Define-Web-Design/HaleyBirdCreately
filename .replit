[[workflows.workflow]]
name = "Comprehensive Verification"
author = 40896524
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Kill any running processes first"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f node || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run all validations simultaneously for maximum efficiency"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run lint"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsc --noEmit"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const { securityMonitor } = require('./server/services/securityMonitor.js'); securityMonitor.validateAssetIntegrity().then(results => console.log('Security Validation:', results.valid ? 'PASSED' : 'FAILED'))\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const { verifyPageLinks } = require('./client/src/utils/navigation-tester.js'); verifyPageLinks().then(results => console.log('Navigation Check:', results.success ? 'PASSED' : 'FAILED'))\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const { runAccessibilityAudit } = require('./client/src/utils/navigation-tester.js'); runAccessibilityAudit().then(results => console.log('Accessibility Score:', results.score, '/ 100'))\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const { validateApiEndpoints } = require('./client/src/utils/api-validator.js'); validateApiEndpoints().then(results => console.log('API Validation:', results.success ? 'PASSED' : 'FAILED'))\""

[[workflows.workflow]]
name = "Checkpoint Creator"
author = 40896524
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Kill any running processes first"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f node || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "# Run full validation and create checkpoint if all pass"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node -e \"const { runTaskVerificationWorkflow } = require('./client/src/utils/workflow-validator.js'); const tasks = [{ id: 'security', description: 'Validate security measures', validationFn: async () => { const { securityMonitor } = require('./server/services/securityMonitor.js'); const result = await securityMonitor.validateAssetIntegrity(); return result.valid; } }, { id: 'accessibility', description: 'Validate accessibility standards', validationFn: async () => { const { runAccessibilityAudit } = require('./client/src/utils/navigation-tester.js'); const result = await runAccessibilityAudit(); return result.score >= 80; } }, { id: 'api', description: 'Validate API endpoints', validationFn: async () => { const { validateApiEndpoints } = require('./client/src/utils/api-validator.js'); const result = await validateApiEndpoints(); return result.success; } }, { id: 'implementation', description: 'Validate overall implementation', validationFn: async () => { const { validateImplementation } = require('./client/src/utils/validate-implementation.js'); const result = await validateImplementation(); return result.success; } }]; runTaskVerificationWorkflow(tasks, 'Comprehensive Checkpoint').then(success => { console.log(success ? '✅ Checkpoint created successfully' : '❌ Cannot create checkpoint - validation failed'); process.exit(success ? 0 : 1); });\""

