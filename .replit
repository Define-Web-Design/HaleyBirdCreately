
entrypoint = "server/index.ts"
hidden = [".config", "package-lock.json"]
compile = ["npm", "run", "build"]

run = "bash run-app.sh"
modules = ["nodejs-20", "postgresql-16"]

[nix]
channel = "stable-23_11"

[env]
PORT = "3000"
NODE_ENV = "development"
REPLIT_DISABLE_PACKAGE_LAYER = "1"
REPLIT_KEEP_PACKAGE_DEV_DEPENDENCIES = "1"

[languages]
[languages.javascript]
pattern = "**/{*.js,*.jsx,*.ts,*.tsx}"
[languages.javascript.languageServer]
start = "typescript-language-server --stdio"

[deployment]
run = ["sh", "-c", "NODE_ENV=production PORT=3000 node dist/index.js"]
deploymentTarget = "gce"
build = ["sh", "-c", "npm install --include=dev && npm run build"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 24678
externalPort = 3000

[workflows]
runButton = "Production Deployment"

[[workflows.workflow]]
name = "Build and Start Production"
author = 40896524
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 NODE_ENV=production node dist/index.js"

[[workflows.workflow]]
name = "Code Snippet Server"
author = 40896524
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "#!/bin/bash"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./master-workflow.sh \"Code Snippet Server\""

