args = "export PORT=3000"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install --include=dev"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=production PORT=3000 node dist/index.js"

